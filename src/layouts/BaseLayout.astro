---
import Footer from '../components/nav/Footer.astro';
import Navbar from '../components/nav/Navbar.astro';
import SEO from '../components/seo/SEO.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Portfolio', description = 'Personal portfolio website.' } =
  Astro.props;
---

<html lang="en">
  <head>
    <SEO title={title} description={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--text)] antialiased">
    <div class="flex min-h-screen flex-col">
      <Navbar />
      <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-10">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
