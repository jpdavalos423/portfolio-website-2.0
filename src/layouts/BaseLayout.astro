---
import Footer from '../components/nav/Footer.astro';
import Navbar from '../components/nav/Navbar.astro';
import SEO from '../components/seo/SEO.astro';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'JP Davalos | Software Engineer',
  description = 'Software engineer portfolio with projects, experience, and contact details.',
  ogImage,
  canonicalPath = Astro.url.pathname,
  schema,
} = Astro.props;

const canonical = Astro.site ? new URL(canonicalPath, Astro.site).toString() : undefined;
const ogImageUrl = Astro.site && ogImage ? new URL(ogImage, Astro.site).toString() : ogImage;
---

<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImageUrl}
      canonical={canonical}
      schema={schema}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--text)] antialiased">
    <div data-site-glow class="relative isolate flex min-h-screen flex-col overflow-hidden">
      <div class="site-glow" aria-hidden="true"></div>

      <div class="relative z-10 flex min-h-screen flex-col">
        <a href="#main-content" class="skip-link">Skip to content</a>
        <Navbar />
        <main id="main-content" tabindex="-1" class="site-shell w-full flex-1 px-6 py-10 sm:py-12">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<script>
  (() => {
    const scope = document.querySelector('[data-site-glow]');
    if (!(scope instanceof HTMLElement)) {
      return;
    }

    const glow = scope.querySelector('.site-glow');
    if (!(glow instanceof HTMLElement)) {
      return;
    }

    if (
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      window.matchMedia('(hover: none)').matches ||
      window.matchMedia('(pointer: coarse)').matches
    ) {
      return;
    }

    const ACTIVE_OPACITY = '0.065';
    const MIN_PERCENT = 5;
    const MAX_PERCENT = 95;

    let frame = 0;
    let pointerX = 0;
    let pointerY = 0;
    let isTrackingPointer = false;

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const updateGlowPosition = () => {
      frame = 0;
      if (document.hidden) {
        return;
      }

      const viewportWidth = window.innerWidth;
      const viewportHeight = window.innerHeight;
      if (viewportWidth === 0 || viewportHeight === 0) {
        return;
      }

      const xPercent = clamp((pointerX / viewportWidth) * 100, MIN_PERCENT, MAX_PERCENT);
      const yPercent = clamp((pointerY / viewportHeight) * 100, MIN_PERCENT, MAX_PERCENT);

      scope.style.setProperty('--site-glow-x', `${xPercent}%`);
      scope.style.setProperty('--site-glow-y', `${yPercent}%`);
    };

    const queueGlowUpdate = (x, y) => {
      pointerX = x;
      pointerY = y;
      if (frame !== 0) {
        return;
      }
      frame = window.requestAnimationFrame(updateGlowPosition);
    };

    const onPointerMove = (event) => {
      if (document.hidden || event.pointerType === 'touch') {
        return;
      }
      queueGlowUpdate(event.clientX, event.clientY);
    };

    const onPointerEnter = (event) => {
      if (event.pointerType === 'touch') {
        return;
      }

      scope.style.setProperty('--site-glow-opacity', ACTIVE_OPACITY);
      glow.style.opacity = '1';

      if (!isTrackingPointer) {
        scope.addEventListener('pointermove', onPointerMove, { passive: true });
        isTrackingPointer = true;
      }

      queueGlowUpdate(event.clientX, event.clientY);
    };

    const onPointerLeave = (event) => {
      if (event.pointerType === 'touch') {
        return;
      }

      glow.style.opacity = '0';
      scope.style.setProperty('--site-glow-opacity', '0');

      if (isTrackingPointer) {
        scope.removeEventListener('pointermove', onPointerMove);
        isTrackingPointer = false;
      }

      if (frame !== 0) {
        window.cancelAnimationFrame(frame);
        frame = 0;
      }
    };

    scope.addEventListener('pointerenter', onPointerEnter);
    scope.addEventListener('pointerleave', onPointerLeave);
  })();
</script>

<style>
  [data-site-glow] {
    --site-glow-x: 50%;
    --site-glow-y: 30%;
    --site-glow-opacity: 0;
  }

  .site-glow {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      700px circle at var(--site-glow-x) var(--site-glow-y),
      rgb(89 179 255 / var(--site-glow-opacity)),
      transparent 62%
    );
    transition: opacity 250ms ease;
  }

  @media (prefers-reduced-motion: reduce), (hover: none), (pointer: coarse) {
    .site-glow {
      display: none;
    }
  }
</style>
