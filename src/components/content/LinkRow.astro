---
interface LinkItem {
  label: string;
  url: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;

const isExternal = (url: string) => /^https?:\/\//.test(url);
---

{
  links.length > 0 && (
    <ul class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
      {links.map((link) => (
        <li class="flex items-center gap-3">
          <a
            href={link.url}
            target={isExternal(link.url) ? '_blank' : undefined}
            rel={isExternal(link.url) ? 'noreferrer' : undefined}
            class="text-[var(--accent)] transition-colors hover:text-[var(--text)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg)]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  )
}
