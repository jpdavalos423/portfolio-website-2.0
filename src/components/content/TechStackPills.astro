---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <ul class="flex flex-wrap gap-2" aria-label="Technology stack">
      {items.map((item) => (
        <li class="rounded-full bg-[var(--surface)] px-3 py-1 text-xs text-[var(--muted)]">
          {item}
        </li>
      ))}
    </ul>
  )
}
