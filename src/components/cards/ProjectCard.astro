---
import type { CollectionEntry } from 'astro:content';
import TechStackPills from '../content/TechStackPills.astro';
import HoverPreview from '../islands/HoverPreview';

interface Props {
  project: CollectionEntry<'projects'>;
  interactive?: boolean;
}

const { project, interactive = false } = Astro.props;
const href = `/projects/${project.slug}`;
const highlights = project.data.highlights.slice(0, 3);
---

<article class="rounded-2xl bg-[var(--surface)] p-4 sm:p-5">
  <a
    href={href}
    class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface)]"
  >
    {
      interactive ? (
        <HoverPreview
          client:visible
          poster={project.data.poster}
          title={project.data.title}
          demoWebm={project.data.demoWebm}
          demoMp4={project.data.demoMp4}
        />
      ) : (
        <div class="overflow-hidden rounded-xl bg-black/30">
          <img
            src={project.data.poster}
            alt={`${project.data.title} poster`}
            loading="lazy"
            decoding="async"
            class="aspect-[16/10] w-full object-cover transition-[transform,filter] duration-300 ease-out motion-safe:group-hover:scale-[1.015] motion-safe:group-hover:brightness-90"
          />
        </div>
      )
    }

    <div class="mt-4 space-y-3">
      <div class="space-y-2">
        <h3 class="text-lg font-semibold tracking-tight text-[var(--text)] group-hover:text-[var(--accent)]">
          {project.data.title}
        </h3>
        <p class="text-sm text-[var(--muted)]">{project.data.summary}</p>
      </div>

      <TechStackPills items={project.data.stack} singleLine={true} />

      {
        highlights.length > 0 && (
          <ul class="flex flex-wrap gap-x-3 gap-y-2 text-xs text-[var(--muted)]" aria-label="Highlights">
            {highlights.map((highlight) => (
              <li class="flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)]" aria-hidden="true"></span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </a>
</article>
