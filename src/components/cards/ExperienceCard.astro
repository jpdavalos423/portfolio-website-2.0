---
import type { CollectionEntry } from 'astro:content';
import TechStackPills from '../content/TechStackPills.astro';

interface Props {
  experience: CollectionEntry<'experience'>;
}

const { experience } = Astro.props;

const href = `/experience/${experience.slug}`;
const endLabel = experience.data.present ? 'Present' : experience.data.end;
const period = `${experience.data.start} - ${endLabel}`;
const highlights = experience.data.highlights.slice(0, 3);
const typeLabel = experience.data.type === 'industry' ? 'professional' : experience.data.type;
---

<article class="rounded-2xl bg-[var(--surface)] p-4 sm:p-6 lg:p-7">
  <a
    href={href}
    class="block space-y-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface)] sm:space-y-5"
  >
    <header class="space-y-2 sm:space-y-3">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 sm:gap-x-3">
        <h3 class="text-lg font-semibold tracking-tight text-[var(--text)] sm:text-xl">{experience.data.role}</h3>
        <span class="text-sm text-[var(--muted)] sm:text-base">@ {experience.data.org}</span>
      </div>

      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--muted)] sm:gap-x-4 sm:text-sm">
        <span>{period}</span>
        <span class="uppercase tracking-wide text-[var(--accent)]">{typeLabel}</span>
      </div>
    </header>

    <TechStackPills items={experience.data.stack} />

    {
      highlights.length > 0 && (
        <ul class="space-y-2 text-sm text-[var(--muted)] sm:space-y-3 sm:text-base sm:leading-7" aria-label="Experience highlights">
          {highlights.map((highlight) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-[var(--accent)]" aria-hidden="true"></span>
              <span>{highlight}</span>
            </li>
          ))}
        </ul>
      )
    }
  </a>
</article>
