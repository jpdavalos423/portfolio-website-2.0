---
const pathname = Astro.url.pathname;

const links = [
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 py-5">
  <a
    href="/"
    class:list={[
      'text-sm font-semibold tracking-tight transition-colors',
      pathname === '/' ? 'text-[var(--text)]' : 'text-[var(--text)] hover:text-[var(--accent)]',
    ]}
  >
    JP Davalos
  </a>

  <ul class="flex items-center gap-5">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'text-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--accent)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg)]',
              isActive(link.href)
                ? 'text-[var(--accent)]'
                : 'text-[var(--muted)] hover:text-[var(--accent)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
