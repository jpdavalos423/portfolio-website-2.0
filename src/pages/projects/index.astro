---
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/cards/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { compareProjectDateDesc } from '../../lib/collections';

const projects = (await getCollection('projects')).sort(compareProjectDateDesc);
---

<BaseLayout
  title="Projects | JP Davalos"
  description="Software projects by JP Davalos with interactive hover previews on the projects index."
>
  <section class="space-y-3" aria-labelledby="projects-page-heading">
    <h1 id="projects-page-heading" class="text-5xl font-semibold tracking-tight sm:text-6xl">
      Projects
    </h1>
    <p class="max-w-2xl text-base leading-7 text-[var(--muted)]">
      A collection of software projects with interactive hover previews on supported cards.
    </p>
  </section>

  <section class="space-y-6 py-8" aria-labelledby="projects-all-heading">
    <div class="space-y-2">
      <h2 id="projects-all-heading" class="text-2xl font-semibold tracking-tight">All projects</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {projects.map((project) => <ProjectCard project={project} interactive={true} />)}
    </div>
  </section>
</BaseLayout>
