---
import { getCollection } from 'astro:content';
import ContactSection from '../components/home/ContactSection.astro';
import ExperienceSnapshot from '../components/home/ExperienceSnapshot.astro';
import Hero from '../components/home/Hero.astro';
import SelectedWork from '../components/home/SelectedWork.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = await getCollection('projects');
const experiences = await getCollection('experience');
---

<BaseLayout
  title="JP Davalos | Software Engineer"
  description="Software engineer portfolio featuring selected projects, experience, and contact information."
>
  <Hero />
  <SelectedWork projects={projects} />
  <ExperienceSnapshot experiences={experiences} />
  <ContactSection />
</BaseLayout>
