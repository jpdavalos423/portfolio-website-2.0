---
import { getCollection } from 'astro:content';
import ExperienceCard from '../../components/cards/ExperienceCard.astro';
import ExperienceSubnav from '../../components/nav/ExperienceSubnav.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { compareExperienceStartDesc } from '../../lib/collections';
import {
  createBreadcrumbSchema,
  createExperienceCollectionSchema,
} from '../../lib/seo';

const items = (await getCollection('experience'))
  .filter((entry) => entry.data.type === 'leadership')
  .sort(compareExperienceStartDesc);
const schema = Astro.site
  ? [
      createExperienceCollectionSchema(
        Astro.site,
        '/experience/leadership',
        'Leadership Experience',
        'Leadership and community experience entries.',
        items,
      ),
      createBreadcrumbSchema(Astro.site, [
        { name: 'Home', path: '/' },
        { name: 'Experience', path: '/experience' },
        { name: 'Leadership', path: '/experience/leadership' },
      ]),
    ]
  : undefined;
---

<BaseLayout
  title="Leadership Experience | JP Davalos"
  description="Leadership experience entries."
  schema={schema}
>
  <div class="space-y-8">
    <header class="space-y-3">
      <p class="text-sm text-[var(--muted)]">Experience</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Leadership</h1>
      <p class="max-w-2xl text-base leading-7 text-[var(--muted)]">
        Leadership roles sorted by start date, newest first.
      </p>
    </header>

    <ExperienceSubnav />

    <div class="grid grid-cols-1 gap-6">
      {items.map((entry) => <ExperienceCard experience={entry} />)}
    </div>
  </div>
</BaseLayout>
